    "/api/admin/users": {
      "get": {
        "tags": ["Admin · Users"],
        "summary": "მომხმარებლების სია",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "query", "schema": { "type": "integer" } },
          { "name": "q",  "in": "query", "schema": { "type": "string" }, "description": "ძიება სახელით / ელ-ფოსტით / კომპანიით" }
        ],
        "responses": {
          "200": { "description": "მომხმარებლები", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/User" } } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "post": {
        "tags": ["Admin · Users"],
        "summary": "მომხმარებლის შექმნა",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name","email","password"],
                "properties": {
                  "name":     { "type": "string" },
                  "email":    { "type": "string", "format": "email" },
                  "company":  { "type": "string" },
                  "role":     { "type": "string", "enum": ["admin","customer"], "default": "customer" },
                  "password": { "type": "string", "minLength": 6 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "შეიქმნა", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "409": { "description": "ელ-ფოსტა უკვე გამოყენებულია" }
        }
      },
      "put": {
        "tags": ["Admin · Users"],
        "summary": "მომხმარებლის განახლება",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id","name","email"],
                "properties": {
                  "id":       { "type": "integer" },
                  "name":     { "type": "string" },
                  "email":    { "type": "string", "format": "email" },
                  "company":  { "type": "string" },
                  "role":     { "type": "string", "enum": ["admin","customer"] },
                  "password": { "type": "string", "description": "ცარიელი = არ შეიცვლება" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "განახლდა" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Admin · Users"],
        "summary": "მომხმარებლის წაშლა",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["id"], "properties": { "id": { "type": "integer" } } } } }
        },
        "responses": {
          "200": { "description": "წაიშალა" },
          "400": { "description": "საკუთარი ანგარიშის წაშლა შეუძლებელია" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
